<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvProfileMainView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:cardCornerRadius="@dimen/_8sdp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_365sdp"
                android:background="?attr/itemBackground"
                android:paddingVertical="@dimen/_5sdp">

                <RelativeLayout
                    android:id="@+id/rvProfileView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_5sdp"
                        android:layout_toStartOf="@+id/ivCloseDialog"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/semi_bold_sans"
                            android:layout_marginStart="@dimen/_7sdp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp"
                            tools:text="James Bond" />

                        <TextView
                            android:id="@+id/txtUserNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_7sdp"
                            android:layout_marginTop="@dimen/_3sdp"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:textColor="?attr/subTextColor"
                            android:textSize="@dimen/_10ssp"
                            tools:text="+91 78628 21545" />

                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivCloseDialog"
                        android:layout_width="@dimen/_22sdp"
                        android:layout_height="@dimen/_22sdp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="@dimen/_7sdp"
                        android:src="@drawable/ic_light_close"/>

                </RelativeLayout>

                <View
                    android:id="@+id/viewOfProfile"
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_below="@+id/rvProfileView"
                    android:layout_marginVertical="@dimen/_5sdp"
                    android:alpha="0.6"
                    android:visibility="gone"
                    tools:visibility="gone"
                    android:background="?attr/subHeadingColor" />

                <ProgressBar
                    android:id="@+id/paginationProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_below="@+id/rvProfileView"
                    android:layout_marginBottom="@dimen/_5sdp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/app_theme_color"
                    android:progressDrawable="@android:drawable/progress_horizontal"
                    android:progressTint="@color/app_theme_color"
                    android:visibility="visible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSenderChatView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/viewOfProfile"
                    android:layout_above="@+id/llSeeFullView"
                    android:orientation="vertical"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_chat_bubble_one" />

                <RelativeLayout
                    android:id="@+id/llSeeFullView"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_25sdp"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivSeeFullChat"
                        android:layout_width="@dimen/_16sdp"
                        android:layout_height="@dimen/_16sdp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginEnd="@dimen/_7sdp"
                        android:src="@drawable/ic_full_view_chat"/>

                </RelativeLayout>

            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cvProfileMainView"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="@dimen/_200sdp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_10sdp"
                app:cardCornerRadius="@dimen/_8sdp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/itemBackground"
                    android:orientation="vertical"
                    android:padding="@dimen/_10sdp">

                    <RelativeLayout
                        android:id="@+id/rvPin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/txtPin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/medium_sans"
                            android:maxLines="1"
                            android:text="@string/pin"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_11ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivPinUnpin"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="4dp"
                            android:padding="0.5dp"
                            android:src="?attr/pinPopup" />

                    </RelativeLayout>

                    <View
                        android:id="@+id/rvPinView"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:id="@+id/rvMarkAsRead"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/medium_sans"
                            android:maxLines="1"
                            android:text="@string/mark_read"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_11ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivMarkAsRead"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:src="?attr/markAsReadPopup" />

                    </RelativeLayout>

                    <View
                        android:id="@+id/rvMarkAsReadView"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:id="@+id/rvAddToPrivateChat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/txtAddToPrivateChats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/medium_sans"
                            android:maxLines="1"
                            android:text="@string/add_to_private_chat"
                            android:layout_toStartOf="@+id/ivPrivateChats"
                            android:layout_marginEnd="5dp"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_11ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivPrivateChats"
                            android:layout_width="@dimen/_16sdp"
                            android:layout_height="@dimen/_16sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:src="?attr/addToPrivateChatPopup" />

                    </RelativeLayout>

                    <View
                        android:id="@+id/rvAddToPrivateChatView"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:id="@+id/rvOpen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/open"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_17sdp"
                            android:layout_height="@dimen/_17sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:src="?attr/openViewPopup" />

                    </RelativeLayout>

                    <View
                        android:id="@+id/rvOpenView"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor"
                        android:visibility="gone" />

                    <RelativeLayout
                        android:id="@+id/rvBlockedMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/txtBlocked"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/medium_sans"
                            android:maxLines="1"
                            android:text="@string/block"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_11ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivBlockUnblock"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:padding="0.5dp"
                            android:src="?attr/blockPopup" />

                    </RelativeLayout>

                    <View
                        android:id="@+id/rvBlockView"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:id="@+id/rvDeleteChat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/medium_sans"
                            android:maxLines="1"
                            android:text="@string/delete_conversation"
                            android:textColor="@color/blocked_user_profile"
                            android:textSize="@dimen/_11ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/ivDelete"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:src="?attr/deletePopup"
                            android:tint="@color/blocked_user_profile" />

                    </RelativeLayout>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cvTransparentView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_10sdp"
                app:layout_constraintEnd_toEndOf="parent"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/_8sdp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@+id/cvProfileMainView">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="invisible"
                    android:padding="@dimen/_10sdp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/pin"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_16sdp"
                            android:layout_height="@dimen/_16sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:src="?attr/pinPopup" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/mark_read"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_17sdp"
                            android:layout_height="@dimen/_19sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:padding="1dp"
                            android:src="?attr/markAsReadPopup" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/add_to_private_chat"
                            android:layout_marginEnd="5dp"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_16sdp"
                            android:layout_height="@dimen/_17sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:padding="1dp"
                            android:scaleType="centerCrop"
                            android:src="?attr/addToPrivateChatPopup" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/open"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_17sdp"
                            android:layout_height="@dimen/_17sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:src="?attr/openViewPopup" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor"
                        android:visibility="gone" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/block"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_17sdp"
                            android:layout_height="@dimen/_17sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:padding="1dp"
                            android:src="?attr/blockPopup" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:alpha="0.6"
                        android:background="?attr/subHeadingColor" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/regular_sans"
                            android:maxLines="1"
                            android:text="@string/delete_conversation"
                            android:textColor="@color/blocked_user_profile"
                            android:textSize="@dimen/_12ssp" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="@dimen/_17sdp"
                            android:layout_height="@dimen/_17sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="5dp"
                            android:padding="1dp"
                            android:src="?attr/deletePopup"
                            android:tint="@color/blocked_user_profile" />

                    </RelativeLayout>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>