<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_15sdp"
        app:cardCornerRadius="@dimen/_8sdp"
        app:cardElevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/itemBackgroundColor"
            android:orientation="vertical"
            android:padding="@dimen/_10sdp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_3sdp"
                android:fontFamily="@font/regular_sans"
                android:text="@string/select_date"
                android:textColor="?attr/titleTextColor"
                android:textSize="@dimen/_12ssp" />

            <TextView
                android:id="@+id/txtSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/txtTitle"
                android:layout_marginTop="@dimen/_3sdp"
                android:fontFamily="@font/semi_bold_sans"
                android:textColor="?attr/titleTextColor"
                android:textSize="@dimen/_14ssp"
                tools:text="29 Apr 2025" />

            <View
                android:id="@+id/viewLine"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_below="@+id/txtSelectedDate"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@color/light_theme_sub_title_color" />

            <RelativeLayout
                android:id="@+id/rvCalendarView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_290sdp"
                android:layout_below="@+id/viewLine"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/_5sdp">

                <FrameLayout
                    android:id="@+id/flCalendarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:visibility="visible" />

                <ProgressBar
                    android:id="@+id/ivProgress"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_centerInParent="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/app_theme_color"
                    android:progressTint="@color/app_theme_color" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/rvCalendarView"
                android:layout_marginTop="@dimen/_5sdp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_7sdp"
                    android:layout_toStartOf="@+id/txtOk"
                    android:fontFamily="@font/medium_sans"
                    android:padding="@dimen/_5sdp"
                    android:text="@string/cancel"
                    android:textColor="?attr/subTextColor"
                    android:textSize="@dimen/_13ssp" />

                <TextView
                    android:id="@+id/txtOk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/medium_sans"
                    android:padding="@dimen/_5sdp"
                    android:text="@string/ok"
                    android:textColor="@color/app_theme_color"
                    android:textSize="@dimen/_13ssp" />

            </RelativeLayout>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</layout>