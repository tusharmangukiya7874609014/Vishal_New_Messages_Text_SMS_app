<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/mainBackground"
        tools:context=".activity.ArchivedActivity">

        <RelativeLayout
            android:id="@+id/rvTopHeaderView"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_32sdp"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:orientation="horizontal"
            tools:visibility="visible">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivBack"
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp"
                android:layout_centerVertical="true"
                android:src="?attr/backIcon" />

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_toStartOf="@+id/rvMultiSelection"
                android:layout_toEndOf="@+id/ivBack"
                android:ellipsize="end"
                android:fontFamily="@font/semi_bold_sans"
                android:maxLines="1"
                android:text="@string/archived"
                android:textColor="?attr/titleTextColor"
                android:textSize="@dimen/_13ssp" />

            <RelativeLayout
                android:id="@+id/rvMultiSelection"
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/itemBackground">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivMultiSelection"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:src="?attr/multiSelection" />

            </RelativeLayout>

        </RelativeLayout>

        <ProgressBar
            android:id="@+id/paginationProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_below="@+id/rvTopHeaderView"
            android:layout_marginVertical="@dimen/_5sdp"
            android:indeterminate="true"
            android:indeterminateTint="@color/app_theme_color"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="@color/app_theme_color"
            android:visibility="visible"
            tools:visibility="visible" />

        <RelativeLayout
            android:id="@+id/rvNoMessageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:visibility="gone"
            tools:visibility="visible">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivNoRecentMessage"
                android:layout_width="@dimen/_140sdp"
                android:layout_height="@dimen/_140sdp"
                android:layout_centerInParent="true"
                android:layout_centerHorizontal="true"
                android:src="@drawable/img_no_message" />

            <TextView
                android:id="@+id/txtNoRecentMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/ivNoRecentMessage"
                android:layout_centerHorizontal="true"
                android:layout_marginHorizontal="@dimen/_12sdp"
                android:layout_marginTop="-8dp"
                android:fontFamily="@font/medium_sans"
                android:text="@string/archived_conversations_will_appear_here"
                android:textAlignment="center"
                android:textColor="?attr/subTextColor"
                android:textSize="@dimen/_12ssp" />

        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvArchivedMessageList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/rvAdsView"
            android:layout_below="@+id/paginationProgress"
            android:layout_marginTop="@dimen/_5sdp"
            android:orientation="vertical"
            android:overScrollMode="never"
            android:paddingBottom="8dp"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_message_history"
            tools:visibility="gone" />

        <include
            android:id="@+id/iSelectionHeader"
            layout="@layout/item_message_selection_header_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="gone" />

        <RelativeLayout
            android:id="@+id/rvAdsView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true">

            <FrameLayout
                android:id="@+id/nativeAdContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_3sdp"
                android:visibility="gone" />

            <include
                android:id="@+id/banner_ad_container"
                layout="@layout/banner_ad_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_3sdp"
                android:visibility="gone" />

        </RelativeLayout>
    </RelativeLayout>
</layout>