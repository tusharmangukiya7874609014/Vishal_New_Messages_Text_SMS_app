<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="activateSimDetails"
            type="Integer" />

        <variable
            name="isMultiSelectionOptionsEnable"
            type="Boolean" />

        <variable
            name="item"
            type="com.texting.sms.messaging_app.model.ChatUser" />

        <variable
            name="searchQuery"
            type="String" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingTop="@dimen/_7sdp"
        app:selectionBackground="@{item.isMessageSelected}">

        <RelativeLayout
            android:id="@+id/rvSelectionView"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_marginTop="@dimen/_7sdp"
            android:visibility="@{isMultiSelectionOptionsEnable ? View.VISIBLE : View.GONE}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivSelectedMark"
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_16sdp"
                android:layout_centerVertical="true"
                android:src="@{isMultiSelectionOptionsEnable ? item.isMessageSelected ? @drawable/img_check : @drawable/bg_oval_selected : @drawable/bg_oval_selected}"
                tools:src="@drawable/bg_oval_selected" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/rvProfileView"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:layout_marginTop="@dimen/_1ssp"
            app:layout_constraintStart_toEndOf="@+id/rvSelectionView"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/cvMessageUserProfile"
                android:layout_width="@dimen/_34sdp"
                android:layout_height="@dimen/_34sdp"
                android:layout_centerInParent="true"
                android:layout_marginTop="@dimen/_3sdp"
                app:cardBackgroundColor="?attr/itemBackgroundColor"
                app:cardCornerRadius="@dimen/_25sdp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:background="@drawable/bg_profile_ios_background">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivOriginalPhotoUri"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerInParent="true"
                        android:scaleType="centerCrop"
                        app:blockedProfile="@{ivBlockMessageUser}"
                        app:messageTitle="@{txtMessageTitle}"
                        app:profileCard="@{cvMessageUserProfile}"
                        app:specialChar="@{txtSpecialChar}"
                        app:profileMessage="@{item.address}" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivBlockMessageUser"
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:layout_centerInParent="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_block"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/txtSpecialChar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:fontFamily="@font/bold_sans"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_16ssp"
                        tools:text="A" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/_14sdp"
            android:layout_height="@dimen/_14sdp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="-1dp"
            android:src="@drawable/ic_pin"
            android:visibility="@{item.isPinned ? View.VISIBLE : View.GONE}"
            app:layout_constraintEnd_toEndOf="@+id/rvProfileView"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <RelativeLayout
            android:id="@+id/rvMessageDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:layout_toEndOf="@+id/rvSimAndTimeView"
            app:layout_constraintEnd_toStartOf="@+id/viewUnreadMessage"
            app:layout_constraintStart_toEndOf="@+id/rvProfileView"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/txtMessageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/semi_bold_sans"
                android:maxWidth="@dimen/_160sdp"
                android:maxLines="1"
                android:textColor="?attr/message_title_color"
                android:textSize="@dimen/features_title_size"
                app:contactAddress="@{item.address}"
                app:searchQuery="@{searchQuery}"
                tools:text="Eyes Clinic" />

            <TextView
                android:id="@+id/txtLastMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/txtMessageTitle"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:fontFamily="@font/regular_sans"
                android:maxLines="2"
                android:text="@{item.latestMessage}"
                android:textColor="?attr/subHeadingColor"
                android:textSize="@dimen/features_sub_title_size"
                app:unreadMessageFont="@{item.unreadCount}"
                tools:text="Good morning. I’m Angela a dental nurse at Eyes Dental ,can I help you?" />

        </RelativeLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rvSimAndTimeView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivSim"
                android:layout_width="@dimen/_12sdp"
                android:layout_height="@dimen/_12sdp"
                android:layout_marginStart="@dimen/_2sdp"
                android:src="@{item.simSlot == 2 ? @drawable/ic_sim_one_view : @drawable/ic_sim_two_view}"
                android:visibility="@{activateSimDetails != 0 ? item.simSlot != 0 ? View.VISIBLE : View.GONE : View.GONE}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/medium_sans"
                android:maxLines="2"
                android:textColor="?attr/subTextColor"
                android:textSize="@dimen/_8ssp"
                app:layout_constraintEnd_toStartOf="@+id/ivSim"
                app:layout_constraintTop_toTopOf="parent"
                app:messageTime="@{item.timestamp}"
                tools:text="May 23" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/viewUnreadMessage"
            android:layout_width="@dimen/_6sdp"
            android:layout_height="@dimen/_6sdp"
            android:layout_below="@+id/rvSimAndTimeView"
            android:layout_alignParentEnd="true"
            android:layout_marginVertical="@dimen/_7sdp"
            android:background="@drawable/bg_theme_oval"
            android:visibility="@{item.unreadCount > 0 ? View.VISIBLE : View.GONE}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvSimAndTimeView"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/rvCopyCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/rvMessageDetails"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/_5sdp"
            android:orientation="horizontal"
            android:padding="4dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvMessageDetails"
            app:otpMessage="@{item.latestMessage}"
            tools:visibility="visible">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivCopyCode"
                android:layout_width="@dimen/_13sdp"
                android:layout_height="@dimen/_13sdp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_copy"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/txtCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_3sdp"
                android:fontFamily="@font/semi_bold_sans"
                android:textColor="@color/app_theme_color"
                android:textSize="@dimen/_10ssp"
                tools:text="Copy OTP : 786285" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginVertical="@dimen/_10sdp"
            android:layout_marginStart="@dimen/_48sdp"
            android:alpha="0.6"
            android:background="?attr/subHeadingColor"
            app:layout_constraintStart_toStartOf="@+id/rvMessageDetails"
            app:layout_constraintTop_toBottomOf="@+id/rvCopyCode" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>