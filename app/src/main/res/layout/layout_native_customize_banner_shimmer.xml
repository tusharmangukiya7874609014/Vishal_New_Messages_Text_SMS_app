<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <com.google.android.libraries.ads.mobile.sdk.nativead.NativeAdView
        android:id="@+id/native_ad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.6dp"
            android:background="?attr/stroke_color" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="?attr/shimmer_effect_box"
            android:padding="7dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@+id/shimmer_cta">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/shimmer_icon"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_rounded_ads_view"
                    android:scaleType="fitCenter" />

                <RelativeLayout
                    android:id="@+id/content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_toEndOf="@+id/shimmer_icon"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/row_two"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/shimmer_ad_notification_view"
                            android:layout_width="18dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_rounded_ads_view"
                            android:gravity="center"
                            android:text="@string/ad"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_7sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/shimmer_primary"
                            android:layout_width="@dimen/_80sdp"
                            android:layout_height="15dp"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/bg_rounded_ads_view"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:textColor="@color/gnt_gray"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_two2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/row_two"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/shimmer_secondary"
                            android:layout_width="150dp"
                            android:layout_height="15dp"
                            android:background="@drawable/bg_rounded_ads_view"
                            android:gravity="end"
                            android:maxLines="1"
                            android:textColor="@color/gnt_gray"
                            android:textSize="12sp" />

                    </LinearLayout>
                </RelativeLayout>
            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/shimmer_cta"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginHorizontal="5dp"
                android:background="@drawable/bg_rounded_ads_view"
                android:textColor="@color/white" />

        </RelativeLayout>
    </com.google.android.libraries.ads.mobile.sdk.nativead.NativeAdView>
</layout>
