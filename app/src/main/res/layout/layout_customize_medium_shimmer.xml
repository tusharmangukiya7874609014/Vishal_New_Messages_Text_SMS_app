<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.6dp"
            android:background="?attr/stroke_color" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="?attr/shimmer_effect_box"
            android:padding="12dp">

            <RelativeLayout
                android:id="@+id/rvTopView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/shimmer_icon"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_rounded_ads_view"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter" />

                <RelativeLayout
                    android:id="@+id/content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_toEndOf="@+id/shimmer_icon"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/llRowOne"
                        android:layout_width="match_parent"
                        android:layout_height="25dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/shimmer_ad_notification_view"
                            android:layout_width="16dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_rounded_ads_view"
                            android:gravity="center"
                            android:text="@string/ad"
                            android:textColor="?attr/titleTextColor"
                            android:textSize="@dimen/_7sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/shimmer_primary"
                            android:layout_width="match_parent"
                            android:layout_height="13dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/bg_rounded_ads_view"
                            android:gravity="center"
                            android:maxLines="1"
                            android:textColor="@color/gnt_gray"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/row_two"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:layout_below="@+id/llRowOne"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/shimmer_body"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_10sdp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_rounded_ads_view"
                            android:maxLines="2"
                            android:textColor="@color/gnt_gray"
                            android:textSize="12sp" />

                    </LinearLayout>
                </RelativeLayout>
            </RelativeLayout>

            <com.google.android.libraries.ads.mobile.sdk.nativead.MediaView
                android:id="@+id/shimmer_media_view"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_below="@+id/rvTopView"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/_7sdp"
                android:background="@drawable/bg_rounded_ads_view" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/shimmer_cta"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_below="@+id/shimmer_media_view"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/bg_rounded_ads_view"
                android:gravity="center"
                android:lines="1"
                android:textAllCaps="false"
                android:textColor="@color/white" />

        </RelativeLayout>
    </RelativeLayout>
</layout>