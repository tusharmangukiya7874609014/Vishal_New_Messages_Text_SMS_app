<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/mainBackground"
        android:padding="@dimen/_8sdp"
        android:orientation="vertical"
        tools:context=".fragment.SendMessagesFragment">

        <LinearLayout
            android:id="@+id/rvSendMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/itemBackground"
            android:orientation="horizontal"
            android:padding="@dimen/_6sdp"
            tools:visibility="visible">

            <RelativeLayout
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_sent_call"
                    app:tint="?attr/subTextColor" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="@dimen/_190sdp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/medium_sans"
                    android:text="@string/send_message"
                    android:textColor="?attr/titleTextColor"
                    android:textSize="@dimen/features_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:layout_marginTop="@dimen/_1sdp"
                    android:fontFamily="@font/regular_sans"
                    android:text="@string/send_message_to_anyone_with_ease"
                    android:textColor="?attr/subHeadingColor"
                    android:textSize="@dimen/features_sub_title_size" />

            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_19sdp"
                    android:layout_height="@dimen/_19sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:src="@drawable/ic_open_view"
                    app:tint="?attr/subTextColor" />

            </RelativeLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/rvViewMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/itemBackground"
            android:layout_marginVertical="@dimen/_7sdp"
            android:orientation="horizontal"
            android:padding="@dimen/_6sdp"
            tools:visibility="visible">

            <RelativeLayout
                android:layout_width="@dimen/_28sdp"
                android:layout_height="@dimen/_28sdp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_message_notification"
                    app:tint="?attr/subTextColor" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="@dimen/_190sdp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:fontFamily="@font/medium_sans"
                    android:text="@string/view_message"
                    android:textColor="?attr/titleTextColor"
                    android:textSize="@dimen/features_title_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:layout_marginTop="@dimen/_1sdp"
                    android:fontFamily="@font/regular_sans"
                    android:text="@string/view_message_by_just_one_tap"
                    android:textColor="?attr/subHeadingColor"
                    android:textSize="@dimen/features_sub_title_size" />

            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/_19sdp"
                    android:layout_height="@dimen/_19sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:src="@drawable/ic_open_view"
                    app:tint="?attr/subTextColor" />

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>
</layout>