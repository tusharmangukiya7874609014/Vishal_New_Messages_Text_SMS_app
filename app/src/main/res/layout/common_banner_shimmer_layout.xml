<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="55dp">

        <View
            android:id="@+id/bannerAdImage"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:background="@drawable/bg_rounded_ads_view" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/medium_sans"
            android:shadowColor="@color/shimmerColor"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="0.00001"
            android:text="@string/loading_ads"
            android:textSize="@dimen/_12ssp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="15dp"
            android:layout_toEndOf="@+id/bannerAdImage"
            android:background="@drawable/bg_rounded_ads_view" />

    </RelativeLayout>
</layout>