<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="com.chat.sms_text.messages.model.ChatUser" />
    </data>

    <LinearLayout
        android:layout_width="@dimen/_50sdp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_5sdp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvProfileView"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:layout_gravity="center_horizontal"
            app:cardCornerRadius="@dimen/_25sdp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivOriginalProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:scaleType="centerCrop"
                    app:blockedProfile="@{ivBlockProfile}"
                    app:messageTitle="@{txtTopContactsName}"
                    app:profileCard="@{cvProfileView}"
                    app:profileMessage="@{item.address}" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivBlockProfile"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_centerInParent="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_block"
                    android:visibility="gone" />

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/txtTopContactsName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/_3sdp"
            android:ellipsize="end"
            app:contactName="@{item.address}"
            android:fontFamily="@font/medium_sans"
            android:maxLines="1"
            android:textColor="?attr/titleTextColor"
            android:textSize="@dimen/_10ssp"
            tools:text="Skyline" />

    </LinearLayout>
</layout>