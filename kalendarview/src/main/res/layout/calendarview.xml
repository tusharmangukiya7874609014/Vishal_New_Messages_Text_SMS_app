<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/ll_calendar_head"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:animateLayoutChanges="true"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:id="@+id/previous_month"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:padding="2dp"
                android:layout_centerVertical="true"
                android:contentDescription="@null"
                android:layout_toStartOf="@+id/display_current_date"
                android:src="@drawable/custom_back" />

            <TextView
                android:id="@+id/display_current_date"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/medium_sans"
                android:gravity="center"
                tools:text="Month Name"
                android:textColor="?attr/titleTextColor"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/next_month"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:layout_centerVertical="true"
                android:padding="2dp"
                android:layout_toEndOf="@+id/display_current_date"
                android:src="@drawable/custom_next" />

        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_calendar_week"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/sun"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Sun"
            android:textColor="#939396"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/mon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Mon"
            android:textColor="#939396"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Tue"
            android:textColor="#939396"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/wed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Wed"
            android:textColor="#939396"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/thu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Thu"
            android:textColor="#939396"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/fri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Fri"
            android:textColor="#939396"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/sat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fontFamily="@font/medium_sans"
            android:gravity="center"
            android:text="Sat"
            android:textColor="#939396"
            android:textSize="14sp" />
    </LinearLayout>

    <GridView
        android:id="@+id/calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="false"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:numColumns="7"
        tools:animateLayoutChanges="false"
        tools:listitem="@layout/calendarview_cell" />

</LinearLayout>